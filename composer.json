{
    "name": "brunocfalcao/eduka-abstracts",
    "description": "Eduka Abstracts - Abstract Classes to be used across Eduka LMS",
    "keywords": [
        "brunocfalcao",
        "eduka"
    ],
    "homepage": "https://github.com/brunocfalcao/eduka-abstracts",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Bruno Falcão",
            "email": "bruno.c.falcao@brunofalcao.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "brunocfalcao/helpers": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "Eduka\\Abstracts\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eduka\\Abstracts\\EdukaAbstractsServiceProvider"
            ]
        }
    }
}
